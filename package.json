{
	"name": "rotector-extension-v2",
	"description": "Real-time warnings about inappropriate Roblox users before you interact with them.",
	"private": true,
	"version": "2.17.0",
	"type": "module",
	"scripts": {
		"dev": "wxt",
		"dev:firefox": "wxt -b firefox --mv2",
		"dev:edge": "wxt -b edge",
		"build": "wxt build",
		"build:firefox": "wxt build -b firefox --mv2",
		"build:edge": "wxt build -b edge",
		"zip": "wxt zip",
		"zip:firefox": "wxt zip -b firefox --mv2",
		"zip:edge": "wxt zip -b edge",
		"check": "svelte-check --tsconfig ./tsconfig.json",
		"lint": "eslint . --cache && prettier --check .",
		"lint:fix": "eslint . --cache --fix && prettier --write .",
		"knip": "knip",
		"knip:production": "knip --production",
		"stylelint": "stylelint \"src/styles/**/*.css\" --cache",
		"stylelint:fix": "stylelint \"src/styles/**/*.css\" --cache --fix",
		"validate:i18n": "node scripts/validate-i18n.js",
		"format:i18n": "node scripts/format-i18n.js",
		"quality": "bun run check && bun run knip && bun run validate:i18n && bun run stylelint && bun run lint:fix",
		"postinstall": "wxt prepare && lefthook install",
		"format": "prettier --write ."
	},
	"devDependencies": {
		"@commitlint/cli": "^20.5.3",
		"@commitlint/config-conventional": "^20.5.3",
		"@eslint/js": "^10.0.1",
		"@tailwindcss/postcss": "^4.2.4",
		"@tailwindcss/vite": "^4.2.4",
		"@types/turndown": "^5.0.6",
		"@wxt-dev/module-svelte": "^2.0.5",
		"autoprefixer": "^10.5.0",
		"dotenv": "^17.4.2",
		"eslint": "^10.3.0",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-better-tailwindcss": "^4.5.0",
		"eslint-plugin-sonarjs": "^4.0.3",
		"eslint-plugin-svelte": "^3.17.1",
		"eslint-plugin-unused-imports": "^4.4.1",
		"globals": "^17.6.0",
		"knip": "^6.12.0",
		"lefthook": "^2.1.6",
		"lightningcss": "^1.32.0",
		"postcss": "^8.5.14",
		"prettier": "^3.8.3",
		"prettier-plugin-svelte": "^3.5.1",
		"prettier-plugin-tailwindcss": "^0.7.4",
		"stylelint": "^17.11.0",
		"stylelint-config-standard": "^40.0.0",
		"svelte": "^5.55.5",
		"svelte-check": "^4.4.8",
		"svelte-eslint-parser": "^1.6.1",
		"tailwindcss": "^4.2.4",
		"tslib": "^2.8.1",
		"typescript": "^6.0.3",
		"typescript-eslint": "^8.59.2",
		"wxt": "^0.20.25"
	},
	"dependencies": {
		"@icons-pack/svelte-simple-icons": "^7.2.0",
		"@lucide/svelte": "^1.14.0",
		"@zumer/snapdom": "^2.12.0",
		"lz-string": "^1.5.0",
		"ogl": "^1.0.11",
		"svelte-highlight": "^7.9.0",
		"svelte-i18n": "^4.0.1",
		"turndown": "^7.2.4",
		"uplot": "^1.6.32",
		"valibot": "^1.4.0",
		"webgl-obj-loader": "^2.0.8"
	}
}
