{
	"name": "rotector-extension-v2",
	"description": "Real-time warnings about inappropriate Roblox users before you interact with them.",
	"private": true,
	"version": "2.15.0",
	"type": "module",
	"scripts": {
		"dev": "wxt",
		"dev:firefox": "wxt -b firefox",
		"dev:edge": "wxt -b edge",
		"build": "wxt build",
		"build:firefox": "wxt build -b firefox",
		"build:edge": "wxt build -b edge",
		"zip": "wxt zip",
		"zip:firefox": "wxt zip -b firefox",
		"zip:edge": "wxt zip -b edge",
		"check": "svelte-check --tsconfig ./tsconfig.json",
		"lint": "eslint . --cache && prettier --check .",
		"lint:fix": "eslint . --cache --fix && prettier --write .",
		"knip": "knip",
		"knip:production": "knip --production",
		"validate:i18n": "node scripts/validate-i18n.js",
		"format:i18n": "node scripts/format-i18n.js",
		"quality": "bun run check && bun run knip && bun run validate:i18n && bun run lint:fix",
		"postinstall": "wxt prepare",
		"format": "prettier --write ."
	},
	"devDependencies": {
		"@eslint/js": "^10.0.1",
		"@tailwindcss/postcss": "^4.2.1",
		"@tailwindcss/vite": "^4.2.1",
		"@types/turndown": "^5.0.6",
		"@wxt-dev/module-svelte": "^2.0.4",
		"autoprefixer": "^10.4.27",
		"dotenv": "^17.3.1",
		"eslint": "^10.0.3",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-better-tailwindcss": "^4.3.2",
		"eslint-plugin-svelte": "^3.15.0",
		"eslint-plugin-unused-imports": "^4.4.1",
		"globals": "^17.4.0",
		"knip": "^5.85.0",
		"lightningcss": "^1.31.1",
		"postcss": "^8.5.8",
		"prettier": "^3.8.1",
		"prettier-plugin-svelte": "^3.5.1",
		"svelte": "^5.53.7",
		"svelte-check": "^4.4.4",
		"svelte-eslint-parser": "^1.6.0",
		"tailwindcss": "^4.2.1",
		"tslib": "^2.8.1",
		"typescript": "^5.9.3",
		"typescript-eslint": "^8.56.1",
		"wxt": "^0.20.18"
	},
	"dependencies": {
		"@icons-pack/svelte-simple-icons": "^7.1.0",
		"lucide-svelte": "^0.577.0",
		"lz-string": "^1.5.0",
		"ogl": "^1.0.11",
		"svelte-highlight": "^7.9.0",
		"svelte-i18n": "^4.0.1",
		"turndown": "^7.2.2",
		"webgl-obj-loader": "^2.0.8"
	}
}
