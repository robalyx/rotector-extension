{
	"name": "rotector-extension-v2",
	"description": "Real-time warnings about inappropriate Roblox users before you interact with them.",
	"private": true,
	"version": "2.17.1",
	"type": "module",
	"scripts": {
		"dev": "wxt",
		"dev:firefox": "wxt -b firefox --mv2",
		"dev:edge": "wxt -b edge",
		"build": "wxt build",
		"build:firefox": "wxt build -b firefox --mv2",
		"build:edge": "wxt build -b edge",
		"zip": "wxt zip",
		"zip:firefox": "wxt zip -b firefox --mv2",
		"zip:edge": "wxt zip -b edge",
		"check": "svelte-check --tsconfig ./tsconfig.json --tsgo --incremental",
		"lint": "oxlint && eslint . --cache && oxfmt --check",
		"lint:fix": "oxlint --fix && eslint . --cache --fix && oxfmt",
		"knip": "knip",
		"knip:production": "knip --production",
		"stylelint": "stylelint \"src/styles/**/*.css\" --cache",
		"stylelint:fix": "stylelint \"src/styles/**/*.css\" --cache --fix",
		"validate:i18n": "node scripts/validate-i18n.js",
		"format:i18n": "node scripts/format-i18n.js",
		"quality": "bun run check && bun run knip && bun run validate:i18n && bun run stylelint && bun run lint:fix",
		"postinstall": "wxt prepare && lefthook install",
		"format": "oxfmt"
	},
	"devDependencies": {
		"@commitlint/cli": "^21.0.2",
		"@commitlint/config-conventional": "^21.0.2",
		"@eslint/css": "^1.3.0",
		"@eslint/js": "^10.0.1",
		"@tailwindcss/postcss": "^4.3.1",
		"@tailwindcss/vite": "^4.3.1",
		"@types/turndown": "^5.0.6",
		"@typescript/native-preview": "^7.0.0-dev.20260621.1",
		"@wxt-dev/module-svelte": "^2.0.5",
		"autoprefixer": "^10.5.0",
		"dotenv": "^17.4.2",
		"eslint": "^10.5.0",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-better-tailwindcss": "^4.6.0",
		"eslint-plugin-oxlint": "^1.70.0",
		"eslint-plugin-sonarjs": "^4.1.0",
		"eslint-plugin-svelte": "^3.19.0",
		"eslint-plugin-unicorn": "^65.0.1",
		"eslint-plugin-unused-imports": "^4.4.1",
		"globals": "^17.6.0",
		"knip": "^6.17.1",
		"lefthook": "^2.1.9",
		"lightningcss": "^1.32.0",
		"oxfmt": "^0.55.0",
		"oxlint": "^1.70.0",
		"postcss": "^8.5.15",
		"stylelint": "^17.13.0",
		"stylelint-config-standard": "^40.0.0",
		"svelte": "^5.56.3",
		"svelte-check": "^4.6.0",
		"svelte-eslint-parser": "^1.8.0",
		"tailwind-csstree": "^0.3.3",
		"tailwindcss": "^4.3.1",
		"tslib": "^2.8.1",
		"typescript": "^6.0.3",
		"typescript-eslint": "^8.61.1",
		"wxt": "^0.20.26"
	},
	"dependencies": {
		"@icons-pack/svelte-simple-icons": "^7.2.0",
		"@lucide/svelte": "^1.21.0",
		"@zumer/snapdom": "^2.12.9",
		"lz-string": "^1.5.0",
		"ogl": "^1.0.11",
		"svelte-highlight": "^7.11.0",
		"svelte-i18n": "^4.0.1",
		"turndown": "^7.2.4",
		"uplot": "^1.6.32",
		"valibot": "^1.4.1",
		"webgl-obj-loader": "^2.0.8"
	},
	"overrides": {
		"vite": "npm:rolldown-vite@7.2.9",
		"@sveltejs/vite-plugin-svelte": "^7.1.2"
	}
}
